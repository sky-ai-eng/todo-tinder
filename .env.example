# Triage Factory — multi-mode environment template.
# Copy to .env, fill in the values below, then:
#   ./triagefactory jwk-init --write-env .env   # populates GOTRUE_JWT_KEYS and GOTRUE_JWT_SECRET
#   docker compose up -d
#
# Required values are left blank; docker-compose.yml uses ${VAR:?} on each
# so an unfilled .env fails fast at `docker compose up` rather than booting
# a stack with placeholder credentials.

# Postgres superuser password. Used for migrations and admin tasks; will
# NOT be the password TF's app pool connects with (the `authenticator`
# role below has its own password).
#
# Generate with: openssl rand -hex 32
# (NOT base64 — docker-compose.yml interpolates this directly into the
# URL-form TF_DATABASE_URL DSN. Base64's `/`, `+`, `=` are URL-reserved
# and would break pgx's connection-string parser; hex avoids the whole
# class of issues. The interpolation happens before TF sees the DSN,
# so url.UserPassword can't encode away the problem.)
POSTGRES_PASSWORD=

# Password for the `supabase_auth_admin` role (GoTrue's DB user). Kept
# distinct from POSTGRES_PASSWORD so a GoTrue compromise doesn't surrender
# superuser credentials. Set this before first `docker compose up`; the
# `postgres-postinit` sidecar reconciles this role password on each
# `docker compose up`, so updates here can be applied after first boot too.
#
# Generate with: openssl rand -hex 32
# (NOT base64 — GoTrue's DB lib requires URL-form connection strings;
# hex avoids every URL-reserved character by construction.)
SUPABASE_AUTH_ADMIN_PASSWORD=

# Password for the `authenticator` role — the role TF's app pool
# connects as for RLS-active request handling. Kept distinct from
# POSTGRES_PASSWORD and SUPABASE_AUTH_ADMIN_PASSWORD so a compromise
# of one pool doesn't surrender the others. The postgres-postinit
# sidecar applies this on every `docker compose up` via
# `ALTER USER authenticator WITH PASSWORD`.
#
# Generate with: openssl rand -hex 32
# (Hex is recommended for consistency with the other role passwords.
# The TF binary builds the app DSN via net/url.UserPassword which
# percent-encodes safely, so this one isn't strictly bound by the
# URL-reserved-char constraint that POSTGRES_PASSWORD and
# SUPABASE_AUTH_ADMIN_PASSWORD are — but using hex everywhere keeps
# rotation runbooks uniform.)
TF_AUTHENTICATOR_PASSWORD=

# Public-facing URL of this deployment. Used for OAuth redirect URIs,
# GoTrue issuer claim, and the cookie domain (D7). No trailing slash.
TF_PUBLIC_URL=

# GitHub OAuth app — create one at https://github.com/settings/developers
# with authorized callback URL ${TF_PUBLIC_URL}/auth/v1/callback.
GH_CLIENT_ID=
GH_CLIENT_SECRET=

# GOTRUE_JWT_KEYS and GOTRUE_JWT_SECRET are appended by
# `triagefactory jwk-init --write-env .env`. Both contain secret material
# (private RSA material + a random HS256 fallback secret) — keep this file
# off VCS.

# Session-encryption key (32 random bytes). AES-GCM master key for
# the access/refresh tokens stored at-rest in public.sessions.
# Rotating this key invalidates every existing session (the ciphertext
# can no longer be decrypted) — plan a forced re-auth event when
# rotating.
#
# Generate with: openssl rand -hex 32
# (base64 also accepted; hex avoids URL-reserved chars in env interp.)
TF_SESSION_ENCRYPTION_KEY=

# Cookie-signing secret (32 random bytes). HMAC-SHA256 key for the
# short-lived OAuth state cookie that carries the PKCE verifier +
# CSRF token through the GitHub roundtrip. Rotating this only
# invalidates in-flight OAuth handshakes (10-minute window) — active
# sessions are NOT affected, so rotation here is low-impact.
#
# Generate with: openssl rand -hex 32
#
# Kept distinct from TF_SESSION_ENCRYPTION_KEY (rather than derived
# from a single master) so the two rotate independently. Matches the
# skynet/authkit convention.
TF_COOKIE_SECRET=
